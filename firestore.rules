rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para a coleção users
    match /users/{userId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, você deve usar autenticação:
      // allow read, write: if request.auth != null;
    }
    
    // Regras para a coleção questions
    match /questions/{questionId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, você deve usar autenticação:
      // allow read, write: if request.auth != null;
    }
    
    // Regras para a coleção gameRules
    match /gameRules/{ruleId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, você deve usar autenticação:
      // allow read, write: if request.auth != null;
    }
    
    // Regras para a coleção userStats (estatísticas dos usuários)
    match /userStats/{userId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, você deve usar autenticação:
      // allow read, write: if request.auth != null;
    }
    
    // Regras para a coleção userProgress (progresso dos usuários)
    match /userProgress/{progressId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, você deve usar autenticação:
      // allow read, write: if request.auth != null;
    }
    
    // Regras para as novas collections da estrutura hierárquica
    match /themes/{themeId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
    }
    
    match /levels/{levelId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
    }
    
    match /question_sets/{setId} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
    }
    
    // Regra geral para qualquer collection não especificada (desenvolvimento)
    match /{document=**} {
      allow read, write: if true; // Permite leitura e escrita para todos (desenvolvimento)
      // Para produção, remover esta regra e usar autenticação específica
    }
  }
}

